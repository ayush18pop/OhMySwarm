{
  "name": "ohmyswarm",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "cd client && npm run dev",
    "build:server": "tsc -p tsconfig.server.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "tsx server/seed.ts"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.2.42",
    "@langchain/langgraph-checkpoint-postgres": "^0.0.5",
    "@open-wallet-standard/core": "^1.1.2",
    "@prisma/client": "^5.22.0",
    "@x402/core": "^2.6.0",
    "@x402/express": "^2.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "viem": "^2.21.54",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
